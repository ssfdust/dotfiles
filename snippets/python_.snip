			"null": "$2不能为空",
		}
	)

snippet		routeclass
abbr		@ns.route() class ...
options		head
	@ns.route('${1:path}')
	class ${2:name}(Resource):
		@jwt_required
		@ns.marshal_with(${3:fields})
		@ns.expect(${4:expect})
		@ns.doc(params=${5:params},
				description="${6:description}",
				responses={
					404: "请求资源不存在",
					403: "禁止操作"
				})
		def ${7:method}(self${8:, args}):
			TARGET
